@prefix : <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/> .

<http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins> rdf:type owl:Ontology ;
                                                                           owl:imports <http://www.w3.org/ns/ssn/> .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#duration
xsd:duration rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith
:affectsPropertyWith rdf:type owl:ObjectProperty ;
                     rdfs:range :Effect ;
                     rdfs:comment "Represents that a Thing has an effect on a Property."@en ;
                     rdfs:label "affectsPropertyWith"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/comparisonOperator
:comparisonOperator rdf:type owl:ObjectProperty ;
                    rdfs:comment "Required to enable OptimalCondition constraints on variable Property values. Since it is not possible to use the standard comparison operators (>, <, >=, <=) on non-literals, this property allows us to do so."@en ;
                    rdfs:label "comparisonOperator"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts
:enacts rdf:type owl:ObjectProperty ;
        rdfs:range :PropertyChange ;
        rdfs:comment "Represents a relation between a thing, such as a System or Actuator, and a PropertyChange."@en ;
        rdfs:label "enacts"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/equalTo
:equalTo rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :comparisonOperator ;
         rdfs:comment "Represents the '=' (equal to) comparison operator for Property-based values."@en ;
         rdfs:label "equalTo"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/forEnablingProperty
:forEnablingProperty rdf:type owl:ObjectProperty ;
                     rdfs:domain :OptimalCondition ;
                     rdfs:range <http://www.w3.org/ns/ssn/Property> ;
                     rdfs:comment "Represents the relation between an OptimalCondition and a Property that enables it."@en ;
                     rdfs:label "forEnablingProperty"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/greaterThan
:greaterThan rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :comparisonOperator ;
             rdfs:comment "Represents the '>' (greater than) comparison operator for Property-based values."@en ;
             rdfs:label "greaterThan"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/greaterThanOrEqualTo
:greaterThanOrEqualTo rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :comparisonOperator ;
                      rdfs:comment "Represents the '>=' (greater than or equal to) comparison operator for Property-based values."@en ;
                      rdfs:label "greaterThanOrEqualTo"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuator
:hasActuator rdf:type owl:ObjectProperty ;
             rdfs:domain :ActuationAction ;
             rdfs:range <http://www.w3.org/ns/sosa/Actuator> ;
             rdfs:comment "The relation between an ActuationExecution and an Actuator it uses."@en ;
             rdfs:label "hasActuator"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasConstraint
:hasConstraint rdf:type owl:ObjectProperty ;
               rdfs:domain :OptimalCondition ;
               rdfs:comment "Represents a relation between an OptimalCondition and a constraint on some Property values."@en ;
               rdfs:label "hasConstraint"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasEnablingConstraint
:hasEnablingConstraint rdf:type owl:ObjectProperty ;
                       rdfs:domain :OptimalCondition ;
                       rdfs:comment "Represents a relation between an OptimalCondition and the constraint that enables it. E.g., one might desire a specific temperature range only if one is home or if it is a specific time of day."@en ;
                       rdfs:label "hasEnablingConstraint"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationModel
:hasSimulationModel rdf:type owl:ObjectProperty ;
                    rdfs:domain <http://www.w3.org/ns/sosa/Platform> ;
                    rdfs:range <http://www.w3.org/ns/sosa/Procedure> ;
                    rdfs:comment "Represents a model used for simulations of the corresponding Platform."@en ;
                    rdfs:label "hasSimulationModel"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isInputOf
:isInputOf rdf:type owl:ObjectProperty ;
           owl:inverseOf <http://www.w3.org/ns/ssn/hasInput> ;
           rdfs:comment "Relation between an Input and its Procedure."@en ;
           rdfs:label "isInputOf"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isOutputOf
:isOutputOf rdf:type owl:ObjectProperty ;
            owl:inverseOf <http://www.w3.org/ns/ssn/hasOutput> ;
            rdfs:comment "Relation between an Output and its Procedure."@en ;
            rdfs:label "isOutputOf"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/lessThan
:lessThan rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :comparisonOperator ;
          rdfs:comment "Represents the '<' (less than) comparison operator for Property-based values."@en ;
          rdfs:label "lessThan"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/lessThanOrEqualTo
:lessThanOrEqualTo rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :comparisonOperator ;
                   rdfs:comment "Represents the '<=' (less than or equal to) comparison operator for Property-based values."@en ;
                   rdfs:label "lessThanOrEqualTo"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/maximizes
:maximizes rdf:type owl:ObjectProperty ;
           rdfs:comment "Represents the relation between a Platform and a Property it wants to maximize."@en ;
           rdfs:label "maximizes"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/minimizes
:minimizes rdf:type owl:ObjectProperty ;
           rdfs:comment "Represents the relation between a Platform and a Property it wants to minimize."@en ;
           rdfs:label "minimizes"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/generateCombinationsOnlyFromOptimalConditions
:generateCombinationsOnlyFromOptimalConditions rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.w3.org/ns/sosa/Platform> ;
                                               rdfs:range xsd:boolean ;
                                               rdfs:comment "Determines how ActionCombination generation for a Platforms future simulations occurs. 'false' generates all possible combinations from all actuators and their states in the instance model. 'true' restricts combination generation to only the relevant actuators and their states that potentially restore violated OptimalConditions."@en ;
                                               rdfs:label "generateCombinationsOnlyFromOptimalConditions"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorName
:hasActuatorName rdf:type owl:DatatypeProperty ;
                 rdfs:comment "Work in progress. Currently enables cohesion with some models and their respective FMUs." .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState
:hasActuatorState rdf:type owl:DatatypeProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :ActuationAction
                                              <http://www.w3.org/ns/sosa/Actuator>
                                            )
                              ] ;
                  rdfs:range rdfs:Literal ;
                  rdfs:comment "Represents a relation between an Actuator and its state."@en ;
                  rdfs:label "hasActuatorState"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasIdentifier
:hasIdentifier rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string ;
               rdfs:comment "Represents a relation from a thing to its identifier."@en ;
               rdfs:label "hasIdentifier"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasPossibleValue
:hasPossibleValue rdf:type owl:DatatypeProperty ;
                  rdfs:domain :ConfigurableParameter ;
                  rdfs:range rdfs:Literal ;
                  rdfs:comment "Represents one value that a ConfigurableParameter can have."@en ;
                  rdfs:label "hasPossibleValue"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasPriority
:hasPriority rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:int ;
             rdfs:comment "Classifies an OptimalCondition as having a specific priority to facilitate DT decision making by ranking. The intended domain is positive integers. The lower the value, the higher the rank and thus the priority."@en ;
             rdfs:label "hasPriority"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationFidelitySeconds
:hasSimulationFidelitySeconds rdf:type owl:DatatypeProperty ;
                              rdfs:domain :FmuModel ;
                              rdfs:range xsd:int ;
                              rdfs:comment "Represents the fidelity of the simulation models (FMUs) with respect to the equations they contain."@en ;
                              rdfs:label "hasSimulationFidelitySeconds"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasTimeLimit
:hasTimeLimit rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:duration ;
              rdfs:comment "Represents a time limit on the duration of the Strategy."@en ;
              rdfs:label "hasTimeLimit"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasURI
:hasURI rdf:type owl:DatatypeProperty ;
        rdfs:domain :FmuModel ;
        rdfs:range xsd:anyURI ;
        rdfs:comment "Refers to an FMUs URI."@en ;
        rdfs:label "hasURI"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue
:hasValue rdf:type owl:DatatypeProperty ;
          rdfs:range rdfs:Literal ;
          rdfs:comment "Describes a relation to a specific value (of a specific type) contained by a property or an Input/Output parameter."@en ;
          rdfs:label "hasValue"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isBreakable
:isBreakable rdf:type owl:DatatypeProperty ;
             rdfs:domain :OptimalCondition ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Represents the relation between an OptimalCondition and a boolean that determines whether that OptimalCondition is breakable (soft) or non-breakable (hard)."@en ;
             rdfs:label "isBreakable"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isParameter
:isParameter rdf:type owl:DatatypeProperty ;
             rdfs:comment "Work in progress. Currently enables cohesion with some models and their respective FMUs." .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/satisfiedBy
:satisfiedBy rdf:type owl:DatatypeProperty ;
             rdfs:domain :OptimalCondition ;
             rdfs:range xsd:dateTimeStamp ;
             rdfs:comment "Represents a relation between an OptimalCondition and the time that OptimalCondition must be satisfied at. In case of no specified time, the OptimalCondition should always be satisfied. Note that due to the lack of a dedicated xsd:timeStamp type, the date portion of the xsd:dateTimeStamp will be ignored."@en ;
             rdfs:label "satisfiedBy"@en .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/Action
:Action rdf:type owl:Class ;
        rdfs:comment "Represents a single system Action."@en ;
        rdfs:label "Action"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ActuationAction
:ActuationAction rdf:type owl:Class ;
                 rdfs:subClassOf :Action ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasActuator ;
                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass <http://www.w3.org/ns/sosa/Actuator>
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasActuatorState ;
                                   owl:cardinality "1"^^xsd:nonNegativeInteger
                                 ] ;
                 owl:disjointWith :ReconfigurationAction ;
                 rdfs:comment "Represents a single system Action with an actuation, either for optimization or regaining optimal conditions."@en ;
                 rdfs:label "ActuationAction"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ConfigurableParameter
:ConfigurableParameter rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.w3.org/ns/ssn/Input> ,
                                       <http://www.w3.org/ns/ssn/Property> ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasPossibleValue ;
                                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasValue ;
                                         owl:cardinality "1"^^xsd:nonNegativeInteger
                                       ] ;
                       rdfs:comment "A parameter not directly observable or actuatable but rather used for configuring an Input to a System or Procedure."@en ;
                       rdfs:label "ConfigurableParameter"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/Effect
:Effect rdf:type owl:Class ;
        rdfs:comment "The type of effect on the value of a property."@en ;
        rdfs:label "Effect"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/FmuModel
:FmuModel rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/sosa/Procedure> ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasSimulationFidelitySeconds ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:int
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasURI ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:anyURI
                          ] ;
          rdfs:comment "Represents a simulation model in the form of a Functional Mock-up Unit (FMU)."@en ;
          rdfs:label "FmuModel"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/OptimalCondition
:OptimalCondition rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasConstraint ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                         owl:onProperty :comparisonOperator ;
                                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                         owl:onClass <http://www.w3.org/ns/ssn/Property>
                                                                       ]
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty :comparisonOperator ;
                                                                         owl:maxQualifiedCardinality "4"^^xsd:nonNegativeInteger ;
                                                                         owl:onClass <http://www.w3.org/ns/ssn/Property>
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://www.w3.org/ns/ssn/forProperty> ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass <http://www.w3.org/ns/ssn/Property>
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasEnablingConstraint ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                         owl:onProperty :comparisonOperator ;
                                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                         owl:onClass <http://www.w3.org/ns/ssn/Property>
                                                                       ]
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty :comparisonOperator ;
                                                                         owl:maxQualifiedCardinality "4"^^xsd:nonNegativeInteger ;
                                                                         owl:onClass <http://www.w3.org/ns/ssn/Property>
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :isBreakable ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:boolean
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasPriority ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:int
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :satisfiedBy ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:dateTimeStamp
                                  ] ;
                  rdfs:comment "Represents a required value range constraint on a Property.  For example, a condition on the temperature of a room could be defined as values greater than 18 and lower than 22 degrees Celsius. Due to the OWA, the subclass definition includes a cardinality restriction of maximum 4 Properties while the restrictions are more strict. This is enforced by additional (external) inference rules."@en ;
                  rdfs:label "OptimalCondition"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange
:PropertyChange rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty :affectsPropertyWith ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :Effect
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://www.w3.org/ns/ssn/forProperty> ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass <http://www.w3.org/ns/ssn/Property>
                                ] ;
                rdfs:comment "Represents a specific property change in a given system, either via a changed configuration property or an actuation on an observable one."@en ;
                rdfs:label "PropertyChange"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ReconfigurationAction
:ReconfigurationAction rdf:type owl:Class ;
                       rdfs:subClassOf :Action ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://www.w3.org/ns/ssn/forProperty> ;
                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :ConfigurableParameter
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasValue ;
                                         owl:cardinality "1"^^xsd:nonNegativeInteger
                                       ] ;
                       rdfs:comment "Represents a single system Action with a parameter reconfiguration, either for optimization or regaining optimal conditions."@en ;
                       rdfs:label "ReconfigurationAction"@en .


###  http://www.w3.org/ns/sosa/Actuator
<http://www.w3.org/ns/sosa/Actuator> rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                       owl:onProperty :hasActuatorState ;
                                                       owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                     ] .


###  http://www.w3.org/ns/sosa/ObservableProperty
<http://www.w3.org/ns/sosa/ObservableProperty> rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :hasValue ;
                                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                                               ] .


###  http://www.w3.org/ns/sosa/Platform
<http://www.w3.org/ns/sosa/Platform> rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                       owl:onProperty :hasSimulationModel ;
                                                       owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass :FmuModel
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :generateCombinationsOnlyFromOptimalConditions ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onDataRange xsd:boolean
                                                     ] .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueDecrease
:ValueDecrease rdf:type owl:NamedIndividual ,
                        :Effect .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueIncrease
:ValueIncrease rdf:type owl:NamedIndividual ,
                        :Effect .


#################################################################
#    Device Energy Models — proactive cost-aware scheduling
#
#    Adds vocabulary so any sosa:Actuator can declare a quantitative
#    energy demand model (battery, thermal load, …). The optimizer reads
#    the model + the device's current observable state and computes the
#    real number of charging hours needed instead of trusting a
#    hard-coded `duration_hours` from the user.
#################################################################

###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasEnergyModel
:hasEnergyModel rdf:type owl:ObjectProperty ;
                rdfs:range :DeviceEnergyModel ;
                rdfs:comment "Attaches an energy demand model to a device (typically a sosa:Actuator). The optimizer uses the model to derive the required charging/heating duration from the device's current observable state."@en ;
                rdfs:label "hasEnergyModel"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasCurrentStateProperty
:hasCurrentStateProperty rdf:type owl:ObjectProperty ;
                         rdfs:domain :DeviceEnergyModel ;
                         rdfs:comment "Points to the sosa:ObservableProperty that represents the device's current state (e.g. battery state-of-charge, water temperature). The corresponding sosa:Sensor's hasHaEntityId tells the system which Home Assistant entity to read."@en ;
                         rdfs:label "hasCurrentStateProperty"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasTargetStateProperty
:hasTargetStateProperty rdf:type owl:ObjectProperty ;
                        rdfs:domain :DeviceEnergyModel ;
                        rdfs:comment "Optional pointer to a Property that holds the default target state when the user doesn't specify one (e.g. default desired SoC = 1.0)."@en ;
                        rdfs:label "hasTargetStateProperty"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasHaEntityId
:hasHaEntityId rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string ;
               rdfs:comment "Maps a Sensor / Actuator individual to its Home Assistant entity_id (e.g. 'input_number.tesla_battery_level'). Lets SmartNode resolve TTL individuals to live HA state via the REST API."@en ;
               rdfs:label "hasHaEntityId"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasCapacityKwh
:hasCapacityKwh rdf:type owl:DatatypeProperty ;
                rdfs:domain :BatteryStorageModel ;
                rdfs:range xsd:double ;
                rdfs:comment "Battery storage capacity in kWh (e.g. 75 for a Tesla Model 3 LR)."@en ;
                rdfs:label "hasCapacityKwh"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasMaxChargePowerKw
:hasMaxChargePowerKw rdf:type owl:DatatypeProperty ;
                     rdfs:domain :BatteryStorageModel ;
                     rdfs:range xsd:double ;
                     rdfs:comment "Maximum sustained charging power in kW for the device's wiring/charger."@en ;
                     rdfs:label "hasMaxChargePowerKw"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isInterruptible
:isInterruptible rdf:type owl:DatatypeProperty ;
                 rdfs:domain :DeviceEnergyModel ;
                 rdfs:range xsd:boolean ;
                 rdfs:comment "Whether scheduled energy delivery may be paused and resumed across non-contiguous slots. Batteries and resistive heaters: true. Continuous-cycle appliances (dishwashers, washing machines): false."@en ;
                 rdfs:label "isInterruptible"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/DeviceEnergyModel
:DeviceEnergyModel rdf:type owl:Class ;
                   rdfs:comment "Abstract energy demand model attached to a device via :hasEnergyModel. Concrete subclasses (BatteryStorageModel, ThermalLoadModel, …) describe how to compute kWh needed from a (currentState, targetState) pair."@en ;
                   rdfs:label "DeviceEnergyModel"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/BatteryStorageModel
:BatteryStorageModel rdf:type owl:Class ;
                     rdfs:subClassOf :DeviceEnergyModel ;
                     rdfs:comment "Battery model parameterised by capacity (kWh) and max sustained charge power (kW). Energy demand for a charging session = (targetSoC − currentSoC) × capacityKwh; required hours = energy / maxPower."@en ;
                     rdfs:label "BatteryStorageModel"@en .


###  http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ThermalLoadModel
