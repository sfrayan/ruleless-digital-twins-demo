:RoomTemperatureIncrease
        rdf:type                 rdt:PropertyChange , owl:NamedIndividual;
        rdt:affectsPropertyWith  rdt:ValueIncrease;
        <http://www.w3.org/ns/ssn/forProperty>
                :RoomTemperature .

:OfficeTemperatureLowerLimit
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "18.0"^^xsd:double .

:RoomTemperature  rdf:type  <http://www.w3.org/ns/sosa/ObservableProperty> , owl:NamedIndividual;
        rdt:hasValue  "17.7"^^xsd:double .

:FakepoolStepChange  rdf:type  rdt:PropertyChangeByActuation , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/forProperty>
                :FakepoolStepProperty .

:HumiditySensorMeasuredRoomHumidity
        rdf:type      <http://www.w3.org/ns/ssn/Property> , <http://www.w3.org/ns/ssn/Output> , owl:NamedIndividual;
        rdt:hasValue  "10.2"^^xsd:double .

:EnergyConsumptionMeterProcedure
        rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasOutput>
                :EnergyConsumptionMeterMeasuredEnergyConsumption .

:EnergyConsumption  rdf:type  <http://www.w3.org/ns/sosa/ObservableProperty> , owl:NamedIndividual;
        rdt:hasValue  "0"^^xsd:double .

:FakepoolFMU  rdf:type  rdt:FmuModel , owl:NamedIndividual;
        rdt:hasSimulationFidelitySeconds
                "900"^^xsd:int;
        rdt:hasURI  "Fakepool.fmu"^^xsd:anyURI .

:MotionSensorProcedure
        rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasOutput>
                :MotionSensorMeasuredMotion .

:PriceSensor  rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :price;
        <http://www.w3.org/ns/ssn/implements>
                :PriceProcedure .

:EnergyConsumptionDecrease
        rdf:type                 rdt:PropertyChange , owl:NamedIndividual;
        rdt:affectsPropertyWith  rdt:ValueDecrease;
        <http://www.w3.org/ns/ssn/forProperty>
                :EnergyConsumption .

:RoomTemperatureLowerLimit2
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "10.0"^^xsd:double .

:Heater  rdf:type             <http://www.w3.org/ns/sosa/Actuator> , owl:NamedIndividual;
        rdt:enacts            :RoomTemperatureIncrease , :EnergyConsumptionIncrease;
        rdt:hasActuatorState  "2"^^xsd:int , "1"^^xsd:int , "0"^^xsd:int .

:RoomTemperatureUpperLimit2
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "10.0"^^xsd:double .

:OfficeHumidityLowerLimit
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "30.0"^^xsd:double .

:MapekCycleSensor  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        rdfs:comment  "Workaround.";
        <http://www.w3.org/ns/ssn/implements>
                :MapekCycleProcedure .

:TemperatureSensor1  rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :RoomTemperature;
        <http://www.w3.org/ns/ssn/implements>
                :TemperatureSensor1Procedure .

:Motion  rdf:type     <http://www.w3.org/ns/sosa/ObservableProperty> , owl:NamedIndividual;
        rdt:hasValue  "True"^^xsd:boolean .

:MapekCycle  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Input> , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        rdt:hasValue  "0"^^xsd:int .

:EnergyConsumptionMeter
        rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :EnergyConsumption;
        <http://www.w3.org/ns/ssn/implements>
                :EnergyConsumptionMeterProcedure .

:TemperatureSensor1Procedure
        rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasOutput>
                :TemperatureSensor1MeasuredRoomTemperature .

<http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1>
        rdf:type     owl:Ontology;
        owl:imports  <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins> .

:FloorHeating  rdf:type       <http://www.w3.org/ns/sosa/Actuator> , owl:NamedIndividual;
        rdt:enacts            :RoomTemperatureIncrease , :EnergyConsumptionIncrease;
        rdt:hasActuatorState  "1"^^xsd:int , "0"^^xsd:int .

:FakepoolStepActuator
        rdf:type              owl:NamedIndividual , <http://www.w3.org/ns/sosa/Actuator>;
        rdt:hasActuatorName   "step";
        rdt:hasActuatorState  "900"^^xsd:int;
        rdt:isParameter       true;
        <http://www.w3.org/ns/sosa/enacts>
                :FakepoolStepChange .

:MotionSensorMeasuredMotion
        rdf:type      <http://www.w3.org/ns/ssn/Property> , <http://www.w3.org/ns/ssn/Output> , owl:NamedIndividual;
        rdt:hasValue  "True"^^xsd:boolean .

:FakepoolStepProperty
        rdf:type      owl:NamedIndividual , <http://www.w3.org/ns/sosa/ObservableProperty>;
        rdt:hasValue  0e+00 .

:RoomHumidity  rdf:type  <http://www.w3.org/ns/sosa/ObservableProperty> , owl:NamedIndividual;
        rdt:hasValue  "10.2"^^xsd:double .

:PriceProcedure  rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasInput>
                :MapekCycle;
        <http://www.w3.org/ns/ssn/hasOutput>
                :price;
        <http://www.w3.org/ns/ssn/implementedBy>
                :PriceSensor .

:RoomHumidityDecrease
        rdf:type                 rdt:PropertyChange , owl:NamedIndividual;
        rdt:affectsPropertyWith  rdt:ValueDecrease;
        <http://www.w3.org/ns/ssn/forProperty>
                :RoomHumidity .

:AccumulatedEnergyTimesPrice
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/ObservableProperty>;
        rdf:type  [ rdf:type                  owl:Restriction;
                    owl:onDataRange           xsd:double;
                    owl:onProperty            rdt:hasValue;
                    owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger
                  ] .

:MapekCycleProcedure  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        rdfs:comment  "Workaround.";
        <http://www.w3.org/ns/ssn/hasOutput>
                :MapekCycle .

:TemperatureSensor2Procedure
        rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasOutput>
                :TemperatureSensor2MeasuredRoomTemperature .

:HumiditySensor  rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :RoomHumidity;
        <http://www.w3.org/ns/ssn/implements>
                :HumiditySensorProcedure .

