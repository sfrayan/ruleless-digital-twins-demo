        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "30.2"^^xsd:double .

:MotionSensor  rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :Motion;
        <http://www.w3.org/ns/ssn/implements>
                :MotionSensorProcedure .

:RoomM370  rdf:type             <http://www.w3.org/ns/sosa/Platform> , owl:NamedIndividual;
