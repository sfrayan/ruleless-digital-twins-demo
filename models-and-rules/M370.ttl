@base <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#>.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xml: <http://www.w3.org/XML/1998/namespace>.
@prefix rdt: <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/>.

<http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1> a owl:Ontology;
                                                                    owl:imports <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins>.
:AccumulatedEnergyTimesPrice a owl:NamedIndividual,
                               <http://www.w3.org/ns/sosa/ObservableProperty>,
                               [a owl:Restriction ; 
                                owl:onProperty rdt:hasValue ; 
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                owl:onDataRange xsd:double].
:Dehumidifier rdt:enacts :RoomHumidityDecrease,
                         :EnergyConsumptionIncrease;
              rdt:hasActuatorState "1"^^xsd:int,
                                   "0"^^xsd:int;
              a <http://www.w3.org/ns/sosa/Actuator>,
                owl:NamedIndividual.
:EnergyConsumption rdt:hasValue "0.0"^^xsd:double;
                   a <http://www.w3.org/ns/sosa/ObservableProperty>,
                     owl:NamedIndividual.
:EnergyConsumptionDecrease rdt:affectsPropertyWith rdt:ValueDecrease;
                           a rdt:PropertyChange,
                             owl:NamedIndividual;
                           <http://www.w3.org/ns/ssn/forProperty> :EnergyConsumption.
:EnergyConsumptionIncrease rdt:affectsPropertyWith rdt:ValueIncrease;
                           a rdt:PropertyChange,
                             owl:NamedIndividual;
                           <http://www.w3.org/ns/ssn/forProperty> :EnergyConsumption.
:EnergyConsumptionMeter a <http://www.w3.org/ns/sosa/Sensor>,
                          owl:NamedIndividual;
                        <http://www.w3.org/ns/sosa/observes> :EnergyConsumption;
                        <http://www.w3.org/ns/ssn/implements> :EnergyConsumptionMeterProcedure.
:EnergyConsumptionMeterMeasuredEnergyConsumption rdt:hasValue "0.0"^^xsd:double;
                                                 a <http://www.w3.org/ns/ssn/Property>,
                                                   <http://www.w3.org/ns/ssn/Output>,
                                                   owl:NamedIndividual.
:EnergyConsumptionMeterProcedure a <http://www.w3.org/ns/sosa/Procedure>,
                                   owl:NamedIndividual;
                                 <http://www.w3.org/ns/ssn/hasOutput> :EnergyConsumptionMeterMeasuredEnergyConsumption.
:FakepoolFMU rdt:hasSimulationFidelitySeconds "900"^^xsd:int;
             rdt:hasURI "Fakepool.fmu"^^xsd:anyURI;
             a rdt:FmuModel,
               owl:NamedIndividual.
:FakepoolStepActuator rdt:hasActuatorName "step";
                      rdt:hasActuatorState "900"^^xsd:int;
                      rdt:isParameter true;
                      a owl:NamedIndividual,
                        <http://www.w3.org/ns/sosa/Actuator>;
                      <http://www.w3.org/ns/sosa/enacts> :FakepoolStepChange.
:FakepoolStepChange a rdt:PropertyChangeByActuation,
                      owl:NamedIndividual;
                    <http://www.w3.org/ns/ssn/forProperty> :FakepoolStepProperty.
:FakepoolStepProperty rdt:hasValue 0e+00;
                      a owl:NamedIndividual,
                        <http://www.w3.org/ns/sosa/ObservableProperty>.
:FloorHeating rdt:enacts :RoomTemperatureIncrease,
                         :EnergyConsumptionIncrease;
              rdt:hasActuatorState "1"^^xsd:int,
                                   "0"^^xsd:int;
              a <http://www.w3.org/ns/sosa/Actuator>,
                owl:NamedIndividual.
:Heater rdt:enacts :RoomTemperatureIncrease,
                   :EnergyConsumptionIncrease;
        rdt:hasActuatorState "2"^^xsd:int,
                             "1"^^xsd:int,
                             "0"^^xsd:int;
        a <http://www.w3.org/ns/sosa/Actuator>,
          owl:NamedIndividual.
:HumiditySensor a <http://www.w3.org/ns/sosa/Sensor>,
                  owl:NamedIndividual;
                <http://www.w3.org/ns/sosa/observes> :RoomHumidity;
                <http://www.w3.org/ns/ssn/implements> :HumiditySensorProcedure.
:HumiditySensorMeasuredRoomHumidity rdt:hasValue "8.065931477520403"^^xsd:double;
                                    a <http://www.w3.org/ns/ssn/Property>,
                                      <http://www.w3.org/ns/ssn/Output>,
                                      owl:NamedIndividual.
:HumiditySensorProcedure a <http://www.w3.org/ns/sosa/Procedure>,
                           owl:NamedIndividual;
                         <http://www.w3.org/ns/ssn/hasOutput> :HumiditySensorMeasuredRoomHumidity.
:MapekCycle rdt:hasValue "0"^^xsd:int;
            a owl:NamedIndividual,
              <http://www.w3.org/ns/ssn/Input>,
              <http://www.w3.org/ns/ssn/Output>,
              <http://www.w3.org/ns/ssn/Property>.
:MapekCycleProcedure a owl:NamedIndividual,
                       <http://www.w3.org/ns/sosa/Procedure>;
                     rdfs:comment "Workaround.";
                     <http://www.w3.org/ns/ssn/hasOutput> :MapekCycle.
:MapekCycleSensor a owl:NamedIndividual,
                    <http://www.w3.org/ns/sosa/Sensor>;
                  rdfs:comment "Workaround.";
                  <http://www.w3.org/ns/ssn/implements> :MapekCycleProcedure.
:Motion rdt:hasValue false;
        a <http://www.w3.org/ns/sosa/ObservableProperty>,
          owl:NamedIndividual.
:MotionActivated rdt:hasValue true;
                 a <http://www.w3.org/ns/ssn/Property>,
                   owl:NamedIndividual.
:MotionSensor a <http://www.w3.org/ns/sosa/Sensor>,
                owl:NamedIndividual;
              <http://www.w3.org/ns/sosa/observes> :Motion;
              <http://www.w3.org/ns/ssn/implements> :MotionSensorProcedure.
:MotionSensorMeasuredMotion rdt:hasValue false;
                            a <http://www.w3.org/ns/ssn/Property>,
                              <http://www.w3.org/ns/ssn/Output>,
                              owl:NamedIndividual.
:MotionSensorProcedure a <http://www.w3.org/ns/sosa/Procedure>,
                         owl:NamedIndividual;
                       <http://www.w3.org/ns/ssn/hasOutput> :MotionSensorMeasuredMotion.
:OfficeHumidityLowerLimit rdt:hasValue "30.0"^^xsd:double;
                          a <http://www.w3.org/ns/ssn/Property>,
                            owl:NamedIndividual.
:OfficeHumidityOptimalCondition rdt:isBreakable true;
                                rdt:satisfiedBy "0001-01-01T09:00:00Z"^^xsd:dateTimeStamp;
                                a [a owl:Restriction ; 
                                   owl:onProperty rdt:hasConstraint ; 
                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                   owl:onClass [owl:intersectionOf ([a owl:Restriction ; 
                                                                    owl:onProperty rdt:greaterThanOrEqualTo ; 
                                                                    owl:hasValue :OfficeHumidityLowerLimit]
                                                                    [a owl:Restriction ; 
                                                                    owl:onProperty rdt:lessThanOrEqualTo ; 
                                                                    owl:hasValue :OfficeHumidityUpperLimit]) ; 
                                                a owl:Class]],
                                  rdt:OptimalCondition,
                                  owl:NamedIndividual;
                                <http://www.w3.org/ns/ssn/forProperty> :RoomHumidity.
:OfficeHumidityUpperLimit rdt:hasValue "50.0"^^xsd:double;
                          a <http://www.w3.org/ns/ssn/Property>,
                            owl:NamedIndividual.
:OfficeTemperatureLowerLimit rdt:hasValue "18.0"^^xsd:double;
                             a <http://www.w3.org/ns/ssn/Property>,
                               owl:NamedIndividual.
:OfficeTemperatureOptimalCondition rdt:forEnablingProperty :Motion;
                                   rdt:isBreakable true;
                                   a [a owl:Restriction ; 
                                      owl:onProperty rdt:hasEnablingConstraint ; 
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                      owl:onClass [a owl:Restriction ; 
                                                   owl:onProperty rdt:equalTo ; 
                                                   owl:hasValue :MotionActivated]],
                                     [a owl:Restriction ; 
                                      owl:onProperty rdt:hasConstraint ; 
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                      owl:onClass [owl:intersectionOf ([a owl:Restriction ; 
                                                                       owl:onProperty rdt:greaterThan ; 
                                                                       owl:hasValue :OfficeTemperatureLowerLimit]
                                                                       [a owl:Restriction ; 
                                                                       owl:onProperty rdt:lessThanOrEqualTo ; 
                                                                       owl:hasValue :OfficeTemperatureUpperLimit]) ; 
                                                   a owl:Class]],
                                     rdt:OptimalCondition,
                                     owl:NamedIndividual;
                                   <http://www.w3.org/ns/ssn/forProperty> :RoomTemperature.
:OfficeTemperatureUpperLimit rdt:hasValue "22.0"^^xsd:double;
                             a <http://www.w3.org/ns/ssn/Property>,
                               owl:NamedIndividual.
:PriceProcedure a <http://www.w3.org/ns/sosa/Procedure>,
                  owl:NamedIndividual;
                <http://www.w3.org/ns/ssn/hasInput> :MapekCycle;
                <http://www.w3.org/ns/ssn/hasOutput> :price;
                <http://www.w3.org/ns/ssn/implementedBy> :PriceSensor.
:PriceSensor a <http://www.w3.org/ns/sosa/Sensor>,
               owl:NamedIndividual;
             <http://www.w3.org/ns/sosa/observes> :price;
             <http://www.w3.org/ns/ssn/implements> :PriceProcedure.
:RoomHumidity rdt:hasValue "8.065931477520403"^^xsd:double;
              a <http://www.w3.org/ns/sosa/ObservableProperty>,
                owl:NamedIndividual.
:RoomHumidityDecrease rdt:affectsPropertyWith rdt:ValueDecrease;
                      a rdt:PropertyChange,
                        owl:NamedIndividual;
                      <http://www.w3.org/ns/ssn/forProperty> :RoomHumidity.
:RoomM370 rdt:generateCombinationsOnlyFromOptimalConditions false;
          rdt:hasSimulationModel :RoomM370FMU;
          rdt:minimizes :AccumulatedEnergyTimesPrice;
          a <http://www.w3.org/ns/sosa/Platform>,
            owl:NamedIndividual;
          <http://www.w3.org/ns/sosa/hosts> :TemperatureSensor2,
                                            :TemperatureSensor1,
                                            :PriceSensor,
                                            :HumiditySensor,
                                            :Heater,
                                            :FloorHeating,
                                            :EnergyConsumptionMeter,
                                            :Dehumidifier.
:RoomM370FMU rdt:hasSimulationFidelitySeconds "100"^^xsd:int;
             rdt:hasURI "roomM370.fmu"^^xsd:anyURI;
             a rdt:FmuModel,
               owl:NamedIndividual.
:RoomTemperature rdt:hasValue "10.0"^^xsd:double;
                 a <http://www.w3.org/ns/sosa/ObservableProperty>,
                   owl:NamedIndividual.
:RoomTemperatureIncrease rdt:affectsPropertyWith rdt:ValueIncrease;
                         a rdt:PropertyChange,
                           owl:NamedIndividual;
                         <http://www.w3.org/ns/ssn/forProperty> :RoomTemperature.
:RoomTemperatureLowerLimit1 rdt:hasValue "27.5"^^xsd:double;
                            a <http://www.w3.org/ns/ssn/Property>,
                              owl:NamedIndividual.
:RoomTemperatureLowerLimit2 rdt:hasValue "10.0"^^xsd:double;
                            a <http://www.w3.org/ns/ssn/Property>,
                              owl:NamedIndividual.
:RoomTemperatureUpperLimit1 rdt:hasValue "30.2"^^xsd:double;
                            a <http://www.w3.org/ns/ssn/Property>,
                              owl:NamedIndividual.
:RoomTemperatureUpperLimit2 rdt:hasValue "10.0"^^xsd:double;
                            a <http://www.w3.org/ns/ssn/Property>,
                              owl:NamedIndividual.
:TemperatureSensor1 a <http://www.w3.org/ns/sosa/Sensor>,
                      owl:NamedIndividual;
                    <http://www.w3.org/ns/sosa/observes> :RoomTemperature;
                    <http://www.w3.org/ns/ssn/implements> :TemperatureSensor1Procedure.
:TemperatureSensor1MeasuredRoomTemperature rdt:hasValue "16.746512725848774"^^xsd:double;
                                           a <http://www.w3.org/ns/ssn/Property>,
                                             <http://www.w3.org/ns/ssn/Output>,
                                             <http://www.w3.org/ns/ssn/Input>,
                                             owl:NamedIndividual.
:TemperatureSensor1Procedure a <http://www.w3.org/ns/sosa/Procedure>,
                               owl:NamedIndividual;
                             <http://www.w3.org/ns/ssn/hasOutput> :TemperatureSensor1MeasuredRoomTemperature.
:TemperatureSensor2 a <http://www.w3.org/ns/sosa/Sensor>,
                      owl:NamedIndividual;
                    <http://www.w3.org/ns/sosa/observes> :RoomTemperature;
                    <http://www.w3.org/ns/ssn/implements> :TemperatureSensor2Procedure.
:TemperatureSensor2MeasuredRoomTemperature rdt:hasValue "16.746512725848774"^^xsd:double;
                                           a <http://www.w3.org/ns/ssn/Property>,
                                             <http://www.w3.org/ns/ssn/Output>,
                                             <http://www.w3.org/ns/ssn/Input>,
                                             owl:NamedIndividual.
:TemperatureSensor2Procedure a <http://www.w3.org/ns/sosa/Procedure>,
                               owl:NamedIndividual;
                             <http://www.w3.org/ns/ssn/hasOutput> :TemperatureSensor2MeasuredRoomTemperature.
:price rdt:hasValue "0.0"^^xsd:double;
       a <http://www.w3.org/ns/sosa/ObservableProperty>,
         owl:NamedIndividual.
