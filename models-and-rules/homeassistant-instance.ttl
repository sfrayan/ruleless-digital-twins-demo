<http://www.semanticweb.org/rayan/ontologies/2025/ha/entity/climate_bedroom_thermostat> a hass:Climate ;
    rdfs:label "Bedroom Thermostat" ;
    rdt:hasActuatorState "auto",
        "cool",
        "dry",
        "fan_only",
        "heat",
        "heat_cool",
        "off",
        "on",
        "range:0.0:250.0:step0.1"^^xsd:string,
        "range:30.0:99.0:step1.0"^^xsd:string ;
    rdt:hasIdentifier "climate.bedroom_thermostat"^^xsd:string ;
    sosa:implements <http://www.semanticweb.org/rayan/ontologies/2025/ha/procedure/bedroom_thermostat> .

