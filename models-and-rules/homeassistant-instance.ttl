        "range:0.0:250.0:step0.1"^^xsd:string,
        "range:30.0:99.0:step1.0"^^xsd:string ;
    rdt:hasIdentifier "climate.office_thermostat"^^xsd:string ;
    sosa:implements <http://www.semanticweb.org/rayan/ontologies/2025/ha/procedure/office_thermostat> .

