@prefix hass: <https://www.foldr.org/profiles/homeassistant/> .
@prefix mine: <http://test.env.namespace/ha/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdt: <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mine: a owl:Ontology ;
    owl:imports sosa:,
        ssn: .

mine:Backup a <http://test.env.namespace/ha/device/Home_Assistant_Home_Assistant_Backup> ;
    rdfs:label "Backup" ;
    sosa:hosts <http://test.env.namespace/ha/entity/sensor_backup_backup_manager_state>,
        <http://test.env.namespace/ha/entity/sensor_backup_last_attempted_automatic_backup>,
        <http://test.env.namespace/ha/entity/sensor_backup_last_successful_automatic_backup>,
        <http://test.env.namespace/ha/entity/sensor_backup_next_scheduled_automatic_backup> .

mine:Sun a sosa:Platform ;
    rdfs:label "Sun" ;
    sosa:hosts <http://test.env.namespace/ha/entity/sensor_sun_next_dawn>,
        <http://test.env.namespace/ha/entity/sensor_sun_next_dusk>,
        <http://test.env.namespace/ha/entity/sensor_sun_next_midnight>,
        <http://test.env.namespace/ha/entity/sensor_sun_next_noon>,
        <http://test.env.namespace/ha/entity/sensor_sun_next_rising>,
        <http://test.env.namespace/ha/entity/sensor_sun_next_setting> .

<http://test.env.namespace/ha/entity/binary_sensor_showcase_entry_open> a sosa:Sensor ;
    rdfs:label "Showcase Entry Open" ;
    rdt:hasIdentifier "binary_sensor.showcase_entry_open"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_entry_open> .

<http://test.env.namespace/ha/entity/binary_sensor_showcase_laundry_done> a sosa:Sensor ;
    rdfs:label "Showcase Laundry Done" ;
    rdt:hasIdentifier "binary_sensor.showcase_laundry_done"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_laundry_done> .

<http://test.env.namespace/ha/entity/binary_sensor_showcase_poor_air_quality> a sosa:Sensor ;
    rdfs:label "Showcase Poor Air Quality" ;
    rdt:hasIdentifier "binary_sensor.showcase_poor_air_quality"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_poor_air_quality> .

<http://test.env.namespace/ha/entity/binary_sensor_showcase_quiet_hours> a sosa:Sensor ;
    rdfs:label "Showcase Quiet Hours" ;
    rdt:hasIdentifier "binary_sensor.showcase_quiet_hours"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_quiet_hours> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_air_purifier> a sosa:Sensor ;
    rdfs:label "Air Purifier State" ;
    rdt:hasIdentifier "input_boolean.showcase_air_purifier"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_air_purifier> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_front_door_open> a sosa:Sensor ;
    rdfs:label "Front Door Open" ;
    rdt:hasIdentifier "input_boolean.showcase_front_door_open"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_front_door_open> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_hallway_light> a sosa:Sensor ;
    rdfs:label "Hallway Light State" ;
    rdt:hasIdentifier "input_boolean.showcase_hallway_light"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_hallway_light> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_hallway_motion> a sosa:Sensor ;
    rdfs:label "Hallway Motion" ;
    rdt:hasIdentifier "input_boolean.showcase_hallway_motion"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_hallway_motion> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_home_occupied> a sosa:Sensor ;
    rdfs:label "Home Occupied" ;
    rdt:hasIdentifier "input_boolean.showcase_home_occupied"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_home_occupied> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_kitchen_light> a sosa:Sensor ;
    rdfs:label "Kitchen Light State" ;
    rdt:hasIdentifier "input_boolean.showcase_kitchen_light"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_kitchen_light> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_laundry_done> a sosa:Sensor ;
    rdfs:label "Laundry Done" ;
    rdt:hasIdentifier "input_boolean.showcase_laundry_done"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_laundry_done> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_laundry_running> a sosa:Sensor ;
    rdfs:label "Laundry Running" ;
    rdt:hasIdentifier "input_boolean.showcase_laundry_running"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_laundry_running> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_living_room_light> a sosa:Sensor ;
    rdfs:label "Living Room Light State" ;
    rdt:hasIdentifier "input_boolean.showcase_living_room_light"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_living_room_light> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_movie_mode> a sosa:Sensor ;
    rdfs:label "Movie Mode" ;
    rdt:hasIdentifier "input_boolean.showcase_movie_mode"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_movie_mode> .

<http://test.env.namespace/ha/entity/input_boolean_showcase_sleep_mode> a sosa:Sensor ;
    rdfs:label "Sleep Mode" ;
    rdt:hasIdentifier "input_boolean.showcase_sleep_mode"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_sleep_mode> .

<http://test.env.namespace/ha/entity/input_number_showcase_air_quality_index> a sosa:Sensor ;
    rdfs:label "Indoor Air Quality Index" ;
    rdt:hasIdentifier "input_number.showcase_air_quality_index"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_air_quality_index> .

<http://test.env.namespace/ha/entity/input_number_showcase_power_draw> a sosa:Sensor ;
    rdfs:label "Estimated Power Draw" ;
    rdt:hasIdentifier "input_number.showcase_power_draw"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_power_draw> .

<http://test.env.namespace/ha/entity/input_number_showcase_temperature> a sosa:Sensor ;
    rdfs:label "Living Room Temperature" ;
    rdt:hasIdentifier "input_number.showcase_temperature"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_temperature> .

<http://test.env.namespace/ha/entity/light_showcase_hallway_light> a hass:Light ;
    rdfs:label "Showcase Hallway Light" ;
    rdt:hasActuatorState "off",
        "on",
        "range:-100.0:100.0:step1.0"^^xsd:string,
        "range:0.0:100.0:step1.0"^^xsd:string,
        "range:0.0:300.0:step1.0"^^xsd:string ;
    rdt:hasIdentifier "light.showcase_hallway_light"^^xsd:string ;
    sosa:implements <http://test.env.namespace/ha/procedure/showcase_hallway_light> .

<http://test.env.namespace/ha/entity/light_showcase_kitchen_light> a hass:Light ;
    rdfs:label "Showcase Kitchen Light" ;
    rdt:hasActuatorState "off",
        "on",
        "range:-100.0:100.0:step1.0"^^xsd:string,
        "range:0.0:100.0:step1.0"^^xsd:string,
        "range:0.0:300.0:step1.0"^^xsd:string ;
    rdt:hasIdentifier "light.showcase_kitchen_light"^^xsd:string ;
    sosa:implements <http://test.env.namespace/ha/procedure/showcase_kitchen_light> .

<http://test.env.namespace/ha/entity/light_showcase_living_room_lamp> a hass:Light ;
    rdfs:label "Showcase Living Room Lamp" ;
    rdt:hasActuatorState "off",
        "on",
        "range:-100.0:100.0:step1.0"^^xsd:string,
        "range:0.0:100.0:step1.0"^^xsd:string,
        "range:0.0:300.0:step1.0"^^xsd:string ;
    rdt:hasIdentifier "light.showcase_living_room_lamp"^^xsd:string ;
    sosa:implements <http://test.env.namespace/ha/procedure/showcase_living_room_lamp> .

<http://test.env.namespace/ha/entity/sensor_showcase_active_lights> a sosa:Sensor ;
    rdfs:label "Showcase Active Lights" ;
    rdt:hasIdentifier "sensor.showcase_active_lights"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_active_lights> .

<http://test.env.namespace/ha/entity/sensor_showcase_air_quality_index> a sosa:Sensor ;
    rdfs:label "Showcase Air Quality Index" ;
    rdt:hasIdentifier "sensor.showcase_air_quality_index"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_air_quality_index> .

<http://test.env.namespace/ha/entity/sensor_showcase_estimated_power_draw> a sosa:Sensor ;
    rdfs:label "Showcase Estimated Power Draw" ;
    rdt:hasIdentifier "sensor.showcase_estimated_power_draw"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_estimated_power_draw> .

<http://test.env.namespace/ha/entity/sensor_showcase_household_summary> a sosa:Sensor ;
    rdfs:label "Showcase Household Summary" ;
    rdt:hasIdentifier "sensor.showcase_household_summary"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_household_summary> .

<http://test.env.namespace/ha/entity/sensor_showcase_laundry_status> a sosa:Sensor ;
    rdfs:label "Showcase Laundry Status" ;
    rdt:hasIdentifier "sensor.showcase_laundry_status"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_laundry_status> .

<http://test.env.namespace/ha/entity/sensor_showcase_living_room_temperature> a sosa:Sensor ;
    rdfs:label "Showcase Living Room Temperature" ;
    rdt:hasIdentifier "sensor.showcase_living_room_temperature"^^xsd:string ;
    sosa:observes <http://test.env.namespace/ha/property/showcase_living_room_temperature> .

<http://test.env.namespace/ha/entity/switch_showcase_air_purifier> a hass:Switch ;
    rdfs:label "Showcase Air Purifier" ;
    rdt:hasActuatorState "off",
        "on" ;
    rdt:hasIdentifier "switch.showcase_air_purifier"^^xsd:string ;
    sosa:implements <http://test.env.namespace/ha/procedure/showcase_air_purifier> .

rdt:hasActuatorState a owl:DatatypeProperty .

rdt:hasIdentifier a owl:DatatypeProperty .

rdt:hasPossibleValue a owl:DatatypeProperty .

hass:Air_Quality rdfs:subClassOf sosa:Sensor .

hass:Alarm_Control_Panel rdfs:subClassOf sosa:Platform .

hass:Button rdfs:subClassOf sosa:Actuator .

hass:Camera rdfs:subClassOf sosa:Platform .

hass:Climate rdfs:subClassOf sosa:Actuator .

hass:Cover rdfs:subClassOf sosa:Actuator .

hass:Device_Tracker rdfs:subClassOf sosa:Sensor .

hass:Fan rdfs:subClassOf sosa:Actuator .

hass:Humidifier rdfs:subClassOf sosa:Actuator .

hass:Input_Select rdfs:subClassOf sosa:Actuator .

hass:Lock rdfs:subClassOf sosa:Actuator .

hass:Media_Player rdfs:subClassOf sosa:Actuator .

hass:Remote rdfs:subClassOf sosa:Actuator .

hass:Siren rdfs:subClassOf sosa:Actuator .

hass:Vacuum rdfs:subClassOf sosa:Actuator .

hass:Valve rdfs:subClassOf sosa:Actuator .

hass:Water_Heater rdfs:subClassOf sosa:Actuator .

hass:Weather rdfs:subClassOf sosa:Sensor .

<http://test.env.namespace/ha/device/Home_Assistant_Home_Assistant_Backup> rdfs:subClassOf sosa:Platform .

