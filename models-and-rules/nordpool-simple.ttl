@base <http://www.semanticweb.org/vs/ontologies/2025/11/untitled-ontology-97#>.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <http://www.semanticweb.org/vs/ontologies/2025/11/untitled-ontology-97#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xml: <http://www.w3.org/XML/1998/namespace>.

<http://www.semanticweb.org/vs/ontologies/2025/11/untitled-ontology-97> a owl:Ontology;
                                                                        owl:imports <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins>.
:DummyChange <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith> <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueIncrease>;
             a owl:NamedIndividual,
               <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChangeByActuation>;
             <http://www.w3.org/ns/ssn/forProperty> :DummyProperty.
:DummyOptCond a owl:NamedIndividual,
                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/OptimalCondition>,
                [a owl:Restriction ; 
                 owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValueConstraint> ; 
                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                 owl:onDataRange [a rdfs:Datatype ; 
                                  owl:onDatatype xsd:double ; 
                                  owl:withRestrictions ([xsd:minInclusive "0.0"^^xsd:double])]];
              <http://www.w3.org/ns/ssn/forProperty> :DummyProperty.
:DummyProcedure a owl:NamedIndividual,
                  <http://www.w3.org/ns/sosa/Procedure>;
                <http://www.w3.org/ns/ssn/hasOutput> :MeasuredOutputProperty.
:DummyProperty a owl:NamedIndividual,
                 <http://www.w3.org/ns/sosa/ObservableProperty>,
                 [a owl:Restriction ; 
                  owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> ; 
                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                  owl:onDataRange xsd:double].
:DummySensor a owl:NamedIndividual,
               <http://www.w3.org/ns/sosa/Sensor>;
             <http://www.w3.org/ns/sosa/observes> :DummyProperty;
             <http://www.w3.org/ns/ssn/implements> :DummyProcedure.
:MeasuredOutputProperty a owl:NamedIndividual,
                          <http://www.w3.org/ns/ssn/Output>,
                          <http://www.w3.org/ns/ssn/Property>,
                          [a owl:Restriction ; 
                           owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> ; 
                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                           owl:onDataRange xsd:double].
:NordPoolFMU <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationFidelitySeconds> "900"^^xsd:int;
             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasURI> "NordPool.fmu"^^xsd:anyURI;
             a owl:NamedIndividual,
               <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/FmuModel>.
:NordPoolTest <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/generateCombinationsOnlyFromOptimalConditions> false;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationModel> :NordPoolFMU;
              a owl:NamedIndividual,
                <http://www.w3.org/ns/sosa/Platform>;
              <http://www.w3.org/ns/sosa/hosts> :UnitActuator.
:PriceMeasure a owl:NamedIndividual,
                <http://www.w3.org/ns/ssn/Output>,
                <http://www.w3.org/ns/ssn/Property>,
                [a owl:Restriction ; 
                 owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> ; 
                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                 owl:onDataRange xsd:double].
:PriceProcedure a owl:NamedIndividual,
                  <http://www.w3.org/ns/sosa/Procedure>;
                <http://www.w3.org/ns/ssn/hasOutput> :PriceMeasure;
                <http://www.w3.org/ns/ssn/implementedBy> :PriceSensor.
:PriceSensor a owl:NamedIndividual,
               <http://www.w3.org/ns/sosa/Sensor>;
             <http://www.w3.org/ns/sosa/observes> :price.
:UnitActuator <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts> :DummyChange;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState> "0"^^xsd:int;
              a owl:NamedIndividual,
                <http://www.w3.org/ns/sosa/Actuator>.
:notFound a owl:NamedIndividual,
            <http://www.w3.org/ns/sosa/ObservableProperty>,
            [a owl:Restriction ; 
             owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> ; 
             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
             owl:onDataRange xsd:boolean].
:price a owl:NamedIndividual,
         <http://www.w3.org/ns/sosa/ObservableProperty>,
         [a owl:Restriction ; 
          owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> ; 
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
          owl:onDataRange xsd:double].
