                                                                                        meta:greaterThanOrEqualTo;
                                                                                <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#withOptimalCondition>
                                                                                        ha:OfficeHumidityOptimalCondition;
                                                                                <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#withOptimalConditionProperty>
                                                                                        ha:OfficeHumidity;
                                                                                <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#withPropertyChangeCheck>
                                                                                        meta:ValueIncrease;
                                                                                <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#withPropertyCheck>
                                                                                        ha:HumidityLowerLimit , ha:OfficeHumidity;
