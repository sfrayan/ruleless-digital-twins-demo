        sosa:observes   ha:price;
        ssn:implements  ha:PriceDummyProcedure .

ha:TempSensor2Procedure
        rdf:type       sosa:Procedure , owl:NamedIndividual;
        ssn:hasOutput  ha:TempSensor2Output .

ha:PriceDummyProcedure
        rdf:type       sosa:Procedure , owl:NamedIndividual;
        ssn:hasOutput  ha:PriceDummyOutput .

ha:MapekCycleProcedure
        rdf:type       sosa:Procedure , owl:NamedIndividual;
        ssn:hasOutput  ha:MapekCycle .

