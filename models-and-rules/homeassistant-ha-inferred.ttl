ha:price  rdf:type     owl:NamedIndividual , sosa:ObservableProperty;
        meta:hasValue  "1.307935"^^xsd:double .

ha:OfficeHumidity  rdf:type  owl:NamedIndividual , sosa:ObservableProperty;
        meta:hasValue  "28"^^xsd:double .

ha:PriceDummySensor  rdf:type  owl:NamedIndividual , sosa:Sensor;
        sosa:observes   ha:price;
        ssn:implements  ha:PriceDummyProcedure .

ha:TempSensor2Procedure
        rdf:type       owl:NamedIndividual , sosa:Procedure;
        ssn:hasOutput  ha:TempSensor2Output .

ha:PriceDummyProcedure
        rdf:type       owl:NamedIndividual , sosa:Procedure;
        ssn:hasOutput  ha:PriceDummyOutput .

ha:MapekCycleProcedure
        rdf:type       owl:NamedIndividual , sosa:Procedure;
        ssn:hasOutput  ha:MapekCycle .

ha:TemperatureUpperLimit
        rdf:type       ssn:Property , owl:NamedIndividual;
        meta:hasValue  "22.0"^^xsd:double .

ha:HumidityLowerLimit
        rdf:type       owl:NamedIndividual , ssn:Property;
        meta:hasValue  "30.0"^^xsd:double .

ha:TempSensor2  rdf:type  owl:NamedIndividual , sosa:Sensor;
        sosa:observes   ha:OfficeTemperature;
        ssn:implements  ha:TempSensor2Procedure .

ha:OfficeFMU  rdf:type  meta:FmuModel , owl:NamedIndividual;
        meta:hasSimulationFidelitySeconds
                "10"^^xsd:int;
        meta:hasURI  "OfficeTwin.fmu"^^xsd:anyURI .

ha:HumiditySensorProcedure
        rdf:type       owl:NamedIndividual , sosa:Procedure;
        ssn:hasOutput  ha:HumiditySensorOutput .

ha:HeaterActuator  rdf:type    owl:NamedIndividual , sosa:Actuator;
        meta:enacts            ha:OfficeTemperatureIncrease;
        meta:hasActuatorState  "0"^^xsd:int , "1"^^xsd:int .

ha:OfficeTemperatureIncrease
        rdf:type                  owl:NamedIndividual , meta:PropertyChange;
        meta:affectsPropertyWith  meta:ValueIncrease;
        ssn:forProperty           ha:OfficeTemperature .

ha:HumiditySensorOutput
        rdf:type       owl:NamedIndividual , ssn:Output , ssn:Property;
        meta:hasValue  "28"^^xsd:double .

ha:MapekCycle  rdf:type  owl:NamedIndividual , ssn:Output , ssn:Property;
        meta:hasValue  "0"^^xsd:int .

ha:PriceOutput  rdf:type  owl:NamedIndividual , ssn:Output , ssn:Property;
        meta:hasValue  "1.03587"^^xsd:double .

ha:PriceProcedure  rdf:type  owl:NamedIndividual , sosa:Procedure;
        ssn:hasInput   ha:MapekCycle;
        ssn:hasOutput  ha:PriceOutput .

ha:MapekCycleSensor  rdf:type  owl:NamedIndividual , sosa:Sensor;
        ssn:implements  ha:MapekCycleProcedure .

ha:FloorHeatingActuator
        rdf:type               owl:NamedIndividual , sosa:Actuator;
        meta:enacts            ha:OfficeTemperatureIncrease;
        meta:hasActuatorState  "0"^^xsd:int , "1"^^xsd:int .

ha:HumiditySensor  rdf:type  owl:NamedIndividual , sosa:Sensor;
        sosa:observes   ha:OfficeHumidity;
        ssn:implements  ha:HumiditySensorProcedure .

ha:OfficePlatform  rdf:type      owl:NamedIndividual , sosa:Platform;
        rdfs:label               "Office Platform (Home Assistant)";
        meta:generateCombinationsOnlyFromOptimalConditions
                false;
        meta:hasSimulationModel  ha:OfficeFMU;
        sosa:hosts               ha:HumiditySensor , ha:TempSensor2 , ha:DehumidifierActuator , ha:HeaterActuator , ha:FloorHeatingActuator , ha:TempSensor1 .

ha:AccumulatedEnergyTimesPrice
        rdf:type       owl:NamedIndividual , ssn:Property;
        meta:hasValue  "0"^^xsd:double .

ha:office-instance  rdf:type  owl:Ontology;
        owl:imports  meta: .

ha:EnergyConsumptionMeterOutput
        rdf:type       owl:NamedIndividual , ssn:Output , ssn:Property;
        meta:hasValue  "0"^^xsd:double .

ha:EnergyConsumptionMeter
        rdf:type        owl:NamedIndividual , sosa:Sensor;
        sosa:observes   ha:EnergyConsumption;
        ssn:implements  ha:EnergyConsumptionMeterProcedure .

ha:TemperatureLowerLimit
        rdf:type       owl:NamedIndividual , ssn:Property;
        meta:hasValue  "18.0"^^xsd:double .

ha:TempSensor2Output  rdf:type  owl:NamedIndividual , ssn:Output , ssn:Property;
        meta:hasValue  "19.6"^^xsd:double .

ha:TempSensor1Procedure
        rdf:type       owl:NamedIndividual , sosa:Procedure;
        ssn:hasOutput  ha:TempSensor1Output .

ha:TempSensor1  rdf:type  owl:NamedIndividual , sosa:Sensor;
        sosa:observes   ha:OfficeTemperature;
        ssn:implements  ha:TempSensor1Procedure .

ha:OfficeTemperature  rdf:type  owl:NamedIndividual , sosa:ObservableProperty;
        meta:hasValue  "19.6"^^xsd:double .

ha:EnergyConsumption  rdf:type  owl:NamedIndividual , sosa:ObservableProperty;
        meta:hasValue  "0"^^xsd:double .

ha:PriceSensor  rdf:type  owl:NamedIndividual , sosa:Sensor;
        sosa:observes   ha:price;
        ssn:implements  ha:PriceProcedure .

ha:PriceDummyOutput  rdf:type  owl:NamedIndividual , ssn:Output , ssn:Property;
        meta:hasValue  "1.58"^^xsd:double .

ha:HumidityUpperLimit
        rdf:type       owl:NamedIndividual , ssn:Property;
        meta:hasValue  "50.0"^^xsd:double .

ha:OfficeHumidityDecrease
        rdf:type                  owl:NamedIndividual , meta:PropertyChange;
        meta:affectsPropertyWith  meta:ValueDecrease;
        ssn:forProperty           ha:OfficeHumidity .

ha:TempSensor1Output  rdf:type  owl:NamedIndividual , ssn:Output , ssn:Property;
        meta:hasValue  "19.6"^^xsd:double .

ha:EnergyConsumptionMeterProcedure
        rdf:type       owl:NamedIndividual , sosa:Procedure;
        ssn:hasOutput  ha:EnergyConsumptionMeterOutput .

ha:DehumidifierActuator
        rdf:type               owl:NamedIndividual , sosa:Actuator;
        meta:enacts            ha:OfficeHumidityDecrease;
        meta:hasActuatorState  "0"^^xsd:int , "1"^^xsd:int .
