                                                                              ]
                                                                            )
                                                      ];
                            owl:onProperty            meta:hasConstraint;
                            owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger
                          ];
        <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#isEnabled>
                true;
