@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix ha: <http://www.semanticweb.org/rayan/ontologies/2025/ha/>.
@prefix meta: <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix sosa: <http://www.w3.org/ns/sosa/>.
@prefix ssn: <http://www.w3.org/ns/ssn/>.

ha:AccumulatedEnergyTimesPrice meta:hasValue "0"^^xsd:double;
                               a ssn:Property,
                                 owl:NamedIndividual.
ha:DehumidifierActuator meta:enacts ha:OfficeHumidityDecrease;
                        meta:hasActuatorState "1"^^xsd:int,
                                              "0"^^xsd:int;
                        a sosa:Actuator,
                          owl:NamedIndividual.
ha:EnergyConsumption meta:hasValue "0"^^xsd:double;
                     a sosa:ObservableProperty,
                       owl:NamedIndividual.
ha:EnergyConsumptionMeter a sosa:Sensor,
                            owl:NamedIndividual;
                          sosa:observes ha:EnergyConsumption;
                          ssn:implements ha:EnergyConsumptionMeterProcedure.
ha:EnergyConsumptionMeterOutput meta:hasValue "0"^^xsd:double;
                                a ssn:Property,
                                  ssn:Output,
                                  owl:NamedIndividual.
ha:EnergyConsumptionMeterProcedure a sosa:Procedure,
                                     owl:NamedIndividual;
                                   ssn:hasOutput ha:EnergyConsumptionMeterOutput.
ha:FloorHeatingActuator meta:enacts ha:OfficeTemperatureIncrease;
                        meta:hasActuatorState "1"^^xsd:int,
                                              "0"^^xsd:int;
                        a sosa:Actuator,
                          owl:NamedIndividual.
ha:HeaterActuator meta:enacts ha:OfficeTemperatureIncrease;
                  meta:hasActuatorState "1"^^xsd:int,
                                        "0"^^xsd:int;
                  a sosa:Actuator,
                    owl:NamedIndividual.
ha:HumidityLowerLimit meta:hasValue "30.0"^^xsd:double;
                      a ssn:Property,
                        owl:NamedIndividual.
ha:HumiditySensor a sosa:Sensor,
                    owl:NamedIndividual;
                  sosa:observes ha:OfficeHumidity;
                  ssn:implements ha:HumiditySensorProcedure.
ha:HumiditySensorOutput meta:hasValue "28"^^xsd:double;
                        a ssn:Property,
                          ssn:Output,
                          owl:NamedIndividual.
ha:HumiditySensorProcedure a sosa:Procedure,
                             owl:NamedIndividual;
                           ssn:hasOutput ha:HumiditySensorOutput.
ha:HumidityUpperLimit meta:hasValue "50.0"^^xsd:double;
                      a ssn:Property,
                        owl:NamedIndividual.
ha:MapekCycle meta:hasValue "0"^^xsd:int;
              a ssn:Property,
                ssn:Output,
                owl:NamedIndividual.
ha:MapekCycleProcedure a sosa:Procedure,
                         owl:NamedIndividual;
                       ssn:hasOutput ha:MapekCycle.
ha:MapekCycleSensor a sosa:Sensor,
                      owl:NamedIndividual;
                    ssn:implements ha:MapekCycleProcedure.
ha:OfficeFMU meta:hasSimulationFidelitySeconds "10"^^xsd:int;
             meta:hasURI "OfficeTwin.fmu"^^xsd:anyURI;
             a owl:NamedIndividual,
               meta:FmuModel.
ha:OfficeHumidity meta:hasValue "28"^^xsd:double;
                  a sosa:ObservableProperty,
                    owl:NamedIndividual.
ha:OfficeHumidityDecrease meta:affectsPropertyWith meta:ValueDecrease;
                          a meta:PropertyChange,
                            owl:NamedIndividual;
                          ssn:forProperty ha:OfficeHumidity.
ha:OfficeHumidityOptimalCondition meta:isBreakable true;
                                  a [a owl:Restriction ; 
                                     owl:onProperty meta:hasConstraint ; 
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                     owl:onClass [owl:intersectionOf ([a owl:Restriction ; 
                                                                      owl:onProperty meta:greaterThanOrEqualTo ; 
                                                                      owl:hasValue ha:HumidityLowerLimit]
                                                                      [a owl:Restriction ; 
                                                                      owl:onProperty meta:lessThanOrEqualTo ; 
                                                                      owl:hasValue ha:HumidityUpperLimit]) ; 
                                                  a owl:Class]],
                                    meta:OptimalCondition,
                                    owl:NamedIndividual;
                                  ssn:forProperty ha:OfficeHumidity.
ha:OfficePlatform meta:generateCombinationsOnlyFromOptimalConditions false;
                  meta:hasSimulationModel ha:OfficeFMU;
                  a sosa:Platform,
                    owl:NamedIndividual;
                  rdfs:label "Office Platform (Home Assistant)";
                  sosa:hosts ha:DehumidifierActuator,
                             ha:FloorHeatingActuator,
                             ha:HeaterActuator,
                             ha:HumiditySensor,
                             ha:TempSensor2,
                             ha:TempSensor1.
ha:OfficeTemperature meta:hasValue "19.6"^^xsd:double;
                     a sosa:ObservableProperty,
                       owl:NamedIndividual.
ha:OfficeTemperatureIncrease meta:affectsPropertyWith meta:ValueIncrease;
                             a meta:PropertyChange,
                               owl:NamedIndividual;
                             ssn:forProperty ha:OfficeTemperature.
ha:OfficeTemperatureOptimalCondition meta:isBreakable true;
                                     a [a owl:Restriction ; 
                                        owl:onProperty meta:hasConstraint ; 
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                        owl:onClass [owl:intersectionOf ([a owl:Restriction ; 
                                                                         owl:onProperty meta:greaterThan ; 
                                                                         owl:hasValue ha:TemperatureLowerLimit]
                                                                         [a owl:Restriction ; 
                                                                         owl:onProperty meta:lessThanOrEqualTo ; 
                                                                         owl:hasValue ha:TemperatureUpperLimit]) ; 
                                                     a owl:Class]],
                                       meta:OptimalCondition,
                                       owl:NamedIndividual;
                                     ssn:forProperty ha:OfficeTemperature.
ha:PriceDummyOutput meta:hasValue "1.58"^^xsd:double;
                    a ssn:Property,
                      ssn:Output,
                      owl:NamedIndividual.
ha:PriceDummyProcedure a sosa:Procedure,
                         owl:NamedIndividual;
                       ssn:hasOutput ha:PriceDummyOutput.
ha:PriceDummySensor a sosa:Sensor,
                      owl:NamedIndividual;
                    sosa:observes ha:price;
                    ssn:implements ha:PriceDummyProcedure.
ha:PriceOutput meta:hasValue "1.07839"^^xsd:double;
               a ssn:Property,
                 ssn:Output,
                 owl:NamedIndividual.
ha:PriceProcedure a sosa:Procedure,
                    owl:NamedIndividual;
                  ssn:hasInput ha:MapekCycle;
                  ssn:hasOutput ha:PriceOutput.
ha:PriceSensor a sosa:Sensor,
                 owl:NamedIndividual;
               sosa:observes ha:price;
               ssn:implements ha:PriceProcedure.
ha:TempSensor1 a sosa:Sensor,
                 owl:NamedIndividual;
               sosa:observes ha:OfficeTemperature;
               ssn:implements ha:TempSensor1Procedure.
ha:TempSensor1Output meta:hasValue "19.6"^^xsd:double;
                     a ssn:Property,
                       ssn:Output,
                       owl:NamedIndividual.
ha:TempSensor1Procedure a sosa:Procedure,
                          owl:NamedIndividual;
                        ssn:hasOutput ha:TempSensor1Output.
ha:TempSensor2 a sosa:Sensor,
                 owl:NamedIndividual;
               sosa:observes ha:OfficeTemperature;
               ssn:implements ha:TempSensor2Procedure.
ha:TempSensor2Output meta:hasValue "19.6"^^xsd:double;
                     a ssn:Property,
                       ssn:Output,
                       owl:NamedIndividual.
ha:TempSensor2Procedure a sosa:Procedure,
                          owl:NamedIndividual;
                        ssn:hasOutput ha:TempSensor2Output.
ha:TemperatureLowerLimit meta:hasValue "18.0"^^xsd:double;
                         a ssn:Property,
                           owl:NamedIndividual.
ha:TemperatureUpperLimit meta:hasValue "22.0"^^xsd:double;
                         a owl:NamedIndividual,
                           ssn:Property.
ha:office-instance a owl:Ontology;
                   owl:imports meta:.
ha:price meta:hasValue "1.329195"^^xsd:double;
         a sosa:ObservableProperty,
           owl:NamedIndividual.
